# SMTP host for sending emails
SMTP_HOST=smtp.example.com

# SMTP port for sending emails
SMTP_PORT=587

# SMTP username for sending emails
SMTP_USER=your-email@example.com

# SMTP password for sending emails
SMTP_PASS=your-password

# Webhook URL for sending notifications
WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Interval in minutes to check website status
CHECK_INTERVAL_MINUTES=30

# Directory to output reports
REPORT_OUTPUT_DIR=reports_output
